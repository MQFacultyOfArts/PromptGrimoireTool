{
  "name": "js-tests",
  "version": "1.0.0",
  "description": "A collaborative tool for prompt iteration, annotation, and sharing in educational contexts.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "vitest run",
    "lint:lockfile": "lockfile-lint --path package-lock.json --type npm --allowed-hosts npm --validate-https --validate-package-names --validate-integrity",
    "lint:lockfile:milkdown": "lockfile-lint --path src/promptgrimoire/static/milkdown/package-lock.json --type npm --allowed-hosts npm --validate-https --validate-package-names --validate-integrity",
    "audit": "npm audit && cd src/promptgrimoire/static/milkdown && npm audit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "happy-dom": "^20.8.4",
    "lockfile-lint": "^5.0.0",
    "npq": "^3.16.2",
    "vitest": "^4.1.0"
  }
}
