# Supply chain safety for npm packages.
# See: https://github.com/lirantal/npm-security-best-practices

# Reject packages published less than 3 days ago (supply chain cooldown).
# Matches uv's exclude-newer = "3 days" for Python packages.
# Requires npm >= 11.10.0.
min-release-age=3

# Disable post-install scripts to prevent supply chain attacks via postinstall.
# Run scripts explicitly when needed: npm rebuild <package>
ignore-scripts=true

# Block git-based dependency URLs from shipping their own .npmrc
# that could re-enable lifecycle scripts.
allow-git=none
