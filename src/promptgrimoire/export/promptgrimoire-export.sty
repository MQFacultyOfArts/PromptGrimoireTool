\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{promptgrimoire-export}[2026/02/12 PromptGrimoire annotation export]

% =============================================================================
% Package dependencies (converted from \usepackage to \RequirePackage)
% =============================================================================

\RequirePackage{xcolor}

% Unicode support (fontspec always needed, luatexja-fontspec conditional)
\RequirePackage{fontspec}

% Static preamble content
\RequirePackage{amsmath}           % Math extensions (\text{} in math mode)
\RequirePackage{microtype}         % Better typography (kerning, protrusion)
\RequirePackage{marginalia}        % Auto-stacking margin notes for LuaLaTeX
\RequirePackage{longtable}
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{calc}
\RequirePackage[hidelinks]{hyperref}
\RequirePackage{changepage}
\RequirePackage{luacolor}  % Required by lua-ul for coloured highlights
\RequirePackage{lua-ul}    % LuaLaTeX highlighting (robust across line breaks)
\RequirePackage{luabidi}   % Bidirectional text support for LuaLaTeX
\RequirePackage{soul}             % Strikethrough (\st) — Pandoc 3.x emits \st{}
\RequirePackage{accsupp}          % PDF /ActualText for emoji accessibility (#274)
\RequirePackage{fancyvrb}  % Verbatim/code blocks from Pandoc syntax highlighting
\RequirePackage[a4paper,left=2.5cm,right=6cm,top=2.5cm,bottom=2.5cm]{geometry}
\RequirePackage[skins,breakable]{tcolorbox}  % For speaker turn borders (breakable for oversized turns)

% =============================================================================
% Fixed commands
% =============================================================================

% Stub for \includegraphics - Pandoc converts <img> tags to this.
% hyperref loads graphicx which defines \includegraphics, so we must
% \renewcommand AFTER all \usepackage calls to survive.
\renewcommand{\includegraphics}[2][]{[image]}

% Pandoc compatibility
\providecommand{\tightlist}{%
  \setlength{\itemsep}{0pt}\setlength{\parskip}{0pt}}

% =============================================================================
% No-op otherlanguage environment
% =============================================================================

% No-op otherlanguage environment - Pandoc generates \begin{otherlanguage}{X}
% for non-English content but we handle multilingual via luatexja + font fallbacks.
% babel (loaded by hyperref/luabidi chain) may define it, so override safely.
% \foreignlanguage{} is stripped in pandoc.py post-processing instead.
\makeatletter
\@ifundefined{otherlanguage}%
  {\newenvironment{otherlanguage}[1]{}{}}%
  {\renewenvironment{otherlanguage}[1]{}{}}
\makeatother

% =============================================================================
% Paragraph formatting
% =============================================================================

% Paragraph formatting for chatbot exports (no indent, paragraph spacing)
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5\baselineskip}
\setlength{\emergencystretch}{3em}  % prevent overfull lines
\setcounter{secnumdepth}{-\maxdimen}  % no section numbering

% =============================================================================
% Static colour definitions
% =============================================================================

% Speaker colours for chatbot turn markers
\definecolor{usercolor}{HTML}{4A90D9}
\definecolor{assistantcolor}{HTML}{7B68EE}
\definecolor{systemcolor}{HTML}{E65100}

% =============================================================================
% Speaker turn environments
% =============================================================================

% Speaker turn environments with left border.
% Uses tcolorbox with breakable to handle arbitrarily long turns without
% hitting TeX's \maxdimen limit (mdframed's framemethod=tikz measured the
% full box height before splitting, causing "! Dimension too large" for
% turns exceeding ~575cm rendered height).
\newtcolorbox{userturn}{
  enhanced, breakable=unlimited,
  frame hidden, boxrule=0pt,
  borderline west={3pt}{0pt}{usercolor},
  left=1em, right=0pt, top=0pt, bottom=0pt,
  before skip=0pt, after skip=0pt,
  colback=white, sharp corners,
}
\newtcolorbox{assistantturn}{
  enhanced, breakable=unlimited,
  frame hidden, boxrule=0pt,
  borderline west={3pt}{0pt}{assistantcolor},
  left=1em, right=0pt, top=0pt, bottom=0pt,
  before skip=0pt, after skip=0pt,
  colback=white, sharp corners,
}
\newtcolorbox{systemturn}{
  enhanced, breakable=unlimited,
  frame hidden, boxrule=0pt,
  borderline west={3pt}{0pt}{systemcolor},
  left=1em, right=0pt, top=0pt, bottom=0pt,
  before skip=0pt, after skip=0pt,
  colback=white, sharp corners,
}

% =============================================================================
% Annotation counter and macro
% =============================================================================

% Usage: \annot{colour-name}{margin content}
% Short annotations go in the margin; long ones become endnotes to avoid
% overflow.  We measure the natural height of the content at margin width
% and switch when it exceeds \annotmaxht (default 4cm ≈ 6 lines).
\newcounter{annotnum}
\newlength{\annotmaxht}
\setlength{\annotmaxht}{4cm}
\newsavebox{\annotbox}
% Long annotations: written to \jobname.endnotes via \write, flushed
% by \flushannotendnotes which \input{}s the file.
\newwrite\annotendfile
\newif\ifannothasendnotes
% When true, ALL annotations go to endnotes (margin overflow fallback).
% Set by the Python export pipeline on recompilation when marginalia
% reports placement problems from the first pass.
\newif\ifannotforceendnotes
\AtBeginDocument{%
  \immediate\openout\annotendfile=\jobname.endnotes\relax
}
\newcommand{\flushannotendnotes}{%
  \immediate\closeout\annotendfile
  \ifannothasendnotes
    \clearpage
    \ifannotforceendnotes
      \section*{Annotations}
    \else
      \section*{Long Annotations}
    \fi
    \input{\jobname.endnotes}%
  \fi
}
% Link affordance icon: small blue arrow signalling a clickable cross-reference.
% Placed inside \hyperref blocks so users discover the bidirectional links.
\newcommand{\linkicon}{{\scriptsize\textcolor{blue!60}{↗}}}

\newcommand{\annot}[2]{%
  \stepcounter{annotnum}%
  % Measure content height at margin width.
  % Use \setbox with \vbox (not \savebox) because #2 may contain \par
  % tokens from multi-paragraph annotations — \savebox scans in
  % restricted horizontal mode which forbids \par.
  \setbox\annotbox=\vbox{\hsize=4.3cm\footnotesize\textbf{\theannotnum.} #2}%
  \ifannotforceendnotes
    % Margin overflow fallback: ALL annotations go to endnotes.
    % Triggered by the Python pipeline when the first compilation pass
    % produced marginalia placement warnings.
    \phantomsection\label{annot-inline:\theannotnum}%
    \hyperref[annot-endnote:\theannotnum]{%
      \textsuperscript{\textcolor{#1}{\textbf{\theannotnum}}}\,\linkicon
    }%
    \global\annothasendnotestrue
    \immediate\write\annotendfile{%
      \noexpand\phantomsection
      \noexpand\label{annot-endnote:\theannotnum}%
      \noexpand\par\noexpand\noindent
      \noexpand\hyperref[annot-inline:\theannotnum]{%
        \noexpand\textcolor{#1}{\noexpand\textbf{\theannotnum.}}\noexpand\linkicon
      }%
      \unexpanded{#2}%
      \noexpand\par\noexpand\medskip
    }%
  \else\ifdim\ht\annotbox>\annotmaxht
    % Long annotation → write to endnotes file, show stub in margin
    \phantomsection\label{annot-inline:\theannotnum}%
    \hyperref[annot-endnote:\theannotnum]{%
      \textsuperscript{\textcolor{#1}{\textbf{\theannotnum}}}\,\linkicon
    }%
    \marginalia[ysep=3pt]{%
      \fcolorbox{#1}{#1!20}{%
        \parbox{4.3cm}{\footnotesize\textbf{\theannotnum.} (see endnotes)}%
      }%
    }%
    \global\annothasendnotestrue
    \immediate\write\annotendfile{%
      \noexpand\phantomsection
      \noexpand\label{annot-endnote:\theannotnum}%
      \noexpand\par\noexpand\noindent
      \noexpand\hyperref[annot-inline:\theannotnum]{%
        \noexpand\textcolor{#1}{\noexpand\textbf{\theannotnum.}}\noexpand\linkicon
      }%
      \unexpanded{#2}%
      \noexpand\par\noexpand\medskip
    }%
  \else
    % Short annotation → margin note
    \textsuperscript{\textcolor{#1}{\textbf{\theannotnum}}}%
    \marginalia[ysep=3pt]{%
      \fcolorbox{#1}{#1!20}{%
        \usebox{\annotbox}%
      }%
    }%
  \fi\fi
}

% Table-safe annotation reference: superscript number only (no \par).
% Used by highlight.lua Table callback when \annot appears inside longtable cells.
% Usage: \annotref{colour-name}
\newcommand{\annotref}[1]{%
  \stepcounter{annotnum}%
  \phantomsection\label{annot-inline:\theannotnum}%
  \hyperref[annot-endnote:\theannotnum]{%
    \textsuperscript{\textcolor{#1}{\textbf{endnote \theannotnum}}}\,\linkicon
  }%
}

% Table-safe annotation endnote: writes annotation body to the endnotes file.
% Called with the number captured from \annotref to ensure superscript/endnote match.
% Usage: \annotendnote{colour-name}{number}{annotation content}
\newcommand{\annotendnote}[3]{%
  \global\annothasendnotestrue
  \immediate\write\annotendfile{%
    \noexpand\phantomsection
    \noexpand\label{annot-endnote:#2}%
    \noexpand\par\noexpand\noindent
    \noexpand\hyperref[annot-inline:#2]{%
      \noexpand\textcolor{#1}{\noexpand\textbf{#2.}}\noexpand\linkicon
    }%
    \unexpanded{#3}%
    \noexpand\par\noexpand\medskip
  }%
}

% =============================================================================
% Paragraph numbering (left-margin display for auto-numbered paragraphs)
% =============================================================================

% \paranumber{N} — places a small grey paragraph number in the left margin.
% Uses \llap to move the number left of the current position without consuming
% horizontal space.  \leavevmode ensures we are in horizontal mode (required
% at paragraph start before \llap).
\newcommand{\paranumber}[1]{%
  \leavevmode\llap{\textcolor{gray}{\scriptsize\textsf{#1}\quad}}%
}

% =============================================================================
% Font setup (static portion -- dynamic font chain built by build_font_preamble())
% =============================================================================

% Safe pass-through default for \cjktext -- overridden by build_font_preamble()
% when CJK text is detected (\renewcommand with \notocjk)
\providecommand{\cjktext}[1]{#1}

\endinput
